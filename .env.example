# MoneyPrinterTurbo hosted platform
MPT_PLATFORM_ENABLED=true
MPT_DATA_DIR=/data

# SubRouter management endpoint. The app appends /v1 internally for
# OpenAI-compatible model calls.
SUBROUTER_BASE_URL=http://subrouter.railway.internal:8080

# Optional global stock video provider keys. Users can also use local uploads
# without these keys.
# PEXELS_API_KEYS=key1,key2
# PIXABAY_API_KEYS=key1,key2
# COVERR_API_KEYS=key1,key2

# Optional platform-managed TTS provider keys. In hosted mode these are set by
# the Railway admin and are not shown to end users.
# AZURE_SPEECH_REGION=eastus
# AZURE_SPEECH_KEY=your-key
# SILICONFLOW_API_KEY=your-key
# MIMO_API_KEY=your-key
# MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# MIMO_TTS_MODEL_NAME=mimo-v2.5-tts
